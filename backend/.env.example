# ============================================
# PDFlab Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# CORS — allowed frontend origin
# Use * for development (allows all origins)
# Set to specific URL in production (e.g. https://your-app.com)
FRONTEND_URL=*

# Request / upload limits
MAX_FILE_SIZE_MB=50
BODY_LIMIT=50mb
UPLOAD_TIMEOUT_MS=120000

# Temp file directory (defaults to OS temp dir)
# TEMP_DIR=/tmp/docu-assistant

# Graceful shutdown timeout (ms)
# SHUTDOWN_TIMEOUT_MS=10000

# ============================================
# AI Provider Configuration
# ============================================
# Active provider: openai | gemini | claude
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-3-haiku-20240307

# Fallback: try other providers if the primary one fails
# Set to true and list provider order
ENABLE_FALLBACK=false
FALLBACK_PROVIDERS=openai,gemini,claude

# AI generation defaults
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# AI safety limits
AI_TIMEOUT_MS=60000
AI_MAX_PROMPT_LENGTH=100000
AI_MAX_DOCUMENT_LENGTH=500000
AI_MAX_RETRIES=1

# ---- Other Third-party APIs ----

# Google Cloud TTS (optional)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Azure Cognitive Services TTS (optional)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# AWS Polly TTS (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
